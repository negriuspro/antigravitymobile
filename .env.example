# ─────────────────────────────────────────────────────────────────────────────
#  AntigravityMobile — .env.example
#  Copiar a .env y completar todos los valores antes de ejecutar.
#  NUNCA commitear .env al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Red / Puertos ─────────────────────────────────────────────────────────────
# En producción usar 80 (nginx es el único entrypoint)
PUBLIC_HTTP_PORT=80

# URL pública de la app (usada por OpenRouter Referer y CORS)
APP_BASE_URL=http://TU_IP_O_DOMINIO

# ── Backend ───────────────────────────────────────────────────────────────────
HUB_HOST=0.0.0.0
HUB_PORT=8000
FILES_BASE_PATH=/data/files
DOCKER_ALLOWED_LABEL=com.antigravity.manage=true

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
SECRET_KEY=cambia_esto_por_una_clave_aleatoria_de_64_chars

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 20
REDIS_PASSWORD=cambia_esto_por_password_redis_seguro
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── AI Providers — dejar vacío para deshabilitar ──────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENAI_API_KEY=
SAMBANOVA_API_KEY=
OPENROUTER_API_KEY=
