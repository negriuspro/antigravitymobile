# ── Puerto público del gateway Nginx ─────────────────────────────────────────
PUBLIC_HTTP_PORT=3000

# ── Backend runtime ───────────────────────────────────────────────────────────
HUB_HOST=0.0.0.0
HUB_PORT=8000
REDIS_URL=redis://redis:6379/0
DOCKER_ALLOWED_LABEL=com.antigravity.manage=true

# ── URL pública de la app (usada por OpenRouter Referer) ─────────────────────
# Cambiar a la IP/dominio real del servidor en producción
APP_BASE_URL=http://TU_IP_O_DOMINIO:3000

# ── Directorio base de archivos accesibles por el agente ─────────────────────
FILES_BASE_PATH=/data/files

# ── Clave secreta para firmar tokens (generar con: openssl rand -hex 32) ─────
SECRET_KEY=cambia_esto_por_una_clave_segura

# ── AI providers. Dejar en blanco para deshabilitar un proveedor ──────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENAI_API_KEY=
SAMBANOVA_API_KEY=
OPENROUTER_API_KEY=
